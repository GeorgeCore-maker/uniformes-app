{
  "name": "uniformes-app",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "serve:ssr:uniformes-app": "node dist/uniformes-app/server/server.mjs",
    "server": "json-server --watch db.json --port 3000",
    "server:prisma": "node server/prisma-api.js",
    "server:api": "ts-node server/app.ts",
    "dev:db": "npm run server",
    "dev:api": "npm run server:prisma",
    "dev:web": "ng serve --port 4200",
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "migrate": "node run-migration.bat",
    "migrate:linux": "bash run-migration.sh",
    "db:migrate:phase1": "./scripts/migrate-database.sh 1",
    "db:migrate:phase2": "./scripts/migrate-database.sh 2",
    "db:migrate:phase3": "./scripts/migrate-database.sh 3",
    "db:backup": "cp db.json backups/db_backup_$(date +%Y%m%d_%H%M%S).json",
    "db:restore": "cp",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:build": "docker-compose build"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^18.2.14",
    "@angular/cdk": "^18.2.14",
    "@angular/common": "^18.2.0",
    "@angular/compiler": "^18.2.0",
    "@angular/core": "^18.2.0",
    "@angular/forms": "^18.2.0",
    "@angular/material": "^18.2.14",
    "@angular/platform-browser": "^18.2.0",
    "@angular/platform-browser-dynamic": "^18.2.0",
    "@angular/platform-server": "^18.2.0",
    "@angular/router": "^18.2.0",
    "@angular/ssr": "^18.2.21",
    "@prisma/client": "^5.22.0",
    "bcrypt": "^5.1.1",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.4.0",
    "express-validator": "^7.2.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "jspdf": "^4.2.0",
    "morgan": "^1.10.0",
    "pg": "^8.12.0",
    "prisma": "^5.22.0",
    "rxjs": "~7.8.0",
    "sqlite3": "^5.1.7",
    "tslib": "^2.3.0",
    "xlsx": "^0.18.5",
    "zone.js": "~0.14.10"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^18.2.21",
    "@angular/cli": "^18.2.21",
    "@angular/compiler-cli": "^18.2.0",
    "@types/bcrypt": "^5.0.2",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.17",
    "@types/jasmine": "~5.1.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/node": "^18.19.130",
    "@types/pg": "^8.11.10",
    "concurrently": "^9.0.1",
    "jasmine-core": "~5.2.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "nodemon": "^3.1.4",
    "ts-node": "^10.9.2",
    "typescript": "~5.5.2"
  }
}
